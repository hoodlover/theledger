{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/deadlines",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/rules-check",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/practice-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/practice-materialize",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/practice-digest",
      "schedule": "0 13 * * 1-5"
    }
  ]
}
