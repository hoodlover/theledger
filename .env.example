# Neon Postgres connection string (separate project from cobbvault)
# Get this from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Drop folder (local watcher for statements + receipts)
DROP_FOLDER_PATH=C:\Users\lance\Documents\The Ledger Drop

# Anthropic key for the document classifier
ANTHROPIC_API_KEY=

# Zoho SMTP for tax-deadline reminders (reuse cobbvault config)
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_SMTP_FROM=

# Secret that Vercel cron (and manual ?key= triggers) must present to hit
# /api/cron/* endpoints. Generate with `openssl rand -base64 32`. Set the
# same value in Vercel project env so the platform-issued cron requests
# pass the gate.
CRON_SECRET=

# Session signing secret. Used to HMAC the auth cookie. Must be at least
# 32 chars; rotate to force everyone to re-login. Generate with
# `openssl rand -base64 48`.
SESSION_SECRET=

# Vercel Blob for receipt + statement storage.
# Shared with cobbvault — use the SAME token in both apps so neither has to
# re-upload files. Get it from the Vercel project that owns the blob store.
BLOB_READ_WRITE_TOKEN=

# Cobbvault's Neon Postgres connection string — used only by
# `npm run backfill:cobbvault` to lift already-classified statements,
# transactions, and account metadata into The Ledger's own DB.
# READ-ONLY usage. Get the pooled connection string from the cobbvault Neon
# project (separate from The Ledger's DATABASE_URL).
COBBVAULT_DATABASE_URL=
